<mvc:View controllerName="com.analyticalreport.controller.chartview"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:viz="sap.viz.ui5.controls"
    xmlns:viz.data="sap.viz.ui5.data"
    xmlns:viz.feeds="sap.viz.ui5.controls.common.feeds"
    xmlns:l="sap.ui.layout">

    <Page title="Analytical Dashboard">

        <content>

            <VBox class="sapUiMediumMargin">

                <!-- HEADER TOOLBAR -->

                <Toolbar>

                    <Title text="Sales Analytics Dashboard" level="H2" />

                    <ToolbarSpacer />

                    <SearchField width="300px" placeholder="Search Month" liveChange="onSearch" />

                </Toolbar>

                <!-- KPI TILES -->

                <HBox wrap="Wrap" justifyContent="SpaceAround" class="sapUiMediumMarginTop">

                    <GenericTile header="Total Sales" subheader="Current Year" class="sapUiTinyMargin">

                        <TileContent>
                            <NumericContent value="250K" scale="USD" />
                        </TileContent>

                    </GenericTile>

                    <GenericTile header="Orders" subheader="Completed Orders" class="sapUiTinyMargin">

                        <TileContent>
                            <NumericContent value="120" />
                        </TileContent>

                    </GenericTile>

                    <GenericTile header="Customers" subheader="Active Customers" class="sapUiTinyMargin">

                        <TileContent>
                            <NumericContent value="80" />
                        </TileContent>

                    </GenericTile>

                </HBox>

                <!-- CHART SECTION -->

                <l:Grid defaultSpan="L6 M6 S12" hSpacing="1" vSpacing="1" class="sapUiMediumMarginTop">

                    <!-- COLUMN CHART -->

                    <Panel headerText="Monthly Sales Analysis" height="450px">

                        <viz:VizFrame id="idColumnChart" vizType="column" width="100%" height="400px">

                            <viz:dataset>

                                <viz.data:FlattenedDataset data="{/SalesData}">

                                    <viz.data:dimensions>

                                        <viz.data:DimensionDefinition name="Month" value="{Month}" />

                                    </viz.data:dimensions>

                                    <viz.data:measures>

                                        <viz.data:MeasureDefinition name="Sales" value="{Sales}" />

                                    </viz.data:measures>

                                </viz.data:FlattenedDataset>

                            </viz:dataset>

                            <viz:feeds>

                                <viz.feeds:FeedItem uid="valueAxis" type="Measure" values="Sales" />

                                <viz.feeds:FeedItem uid="categoryAxis" type="Dimension" values="Month" />

                            </viz:feeds>

                        </viz:VizFrame>

                    </Panel>

                    <!-- DONUT CHART -->

                    <Panel headerText="Department Distribution" height="450px">

                        <viz:VizFrame id="idDonutChart" vizType="donut" width="100%" height="400px">

                            <viz:dataset>

                                <viz.data:FlattenedDataset data="{/DepartmentData}">

                                    <viz.data:dimensions>

                                        <viz.data:DimensionDefinition name="Department" value="{Department}" />

                                    </viz.data:dimensions>

                                    <viz.data:measures>

                                        <viz.data:MeasureDefinition name="Employees" value="{Count}" />

                                    </viz.data:measures>

                                </viz.data:FlattenedDataset>

                            </viz:dataset>

                            <viz:feeds>

                                <viz.feeds:FeedItem uid="size" type="Measure" values="Employees" />

                                <viz.feeds:FeedItem uid="color" type="Dimension" values="Department" />

                            </viz:feeds>

                        </viz:VizFrame>

                    </Panel>

                </l:Grid>

                <!-- ANALYTICAL TABLE -->

                <Table id="idTable" growing="true" growingScrollToLoad="true" items="{/SalesData}" class="sapUiMediumMarginTop">

                    <headerToolbar>

                        <Toolbar>

                            <Title text="Sales Details" />

                        </Toolbar>

                    </headerToolbar>

                    <columns>

                        <Column>
                            <Text text="Month" />
                        </Column>

                        <Column>
                            <Text text="Sales" />
                        </Column>

                        <Column>
                            <Text text="Profit" />
                        </Column>

                    </columns>

                    <items>

                        <ColumnListItem>

                            <cells>

                                <ObjectIdentifier title="{Month}" />

                                <ObjectNumber number="{Sales}" />

                                <ObjectNumber number="{Profit}" />

                            </cells>

                        </ColumnListItem>

                    </items>

                </Table>

            </VBox>

        </content>

    </Page>

</mvc:View>